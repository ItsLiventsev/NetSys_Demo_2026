## ⚡ Быстрые команды (шпаргалка)

```bash
# Установка имени хоста (FQDN)
mcedit /etc/hostname
# → hq-srv.au-team.irpo

# Перезагрузка сети
systemctl restart network

# Создание пользователя sshuser
useradd -u 2026 sshuser
passwd sshuser  # P@ssw0rd
usermod -aG wheel sshuser

# sudo без пароля (sudoers)
# Раскомментировать: %wheel ALL=(ALL) NOPASSWD: ALL

# Включение IP-форвардинга
sed -i 's/^net.ipv4.ip_forward.*/net.ipv4.ip_forward = 1/' /etc/sysctl.conf
sysctl -p

# Часовой пояс (Москва)
timedatectl set-timezone Europe/Moscow

# SSH-конфиг (/etc/ssh/sshd_config)
Port 2026
MaxAuthTries 2
AllowUsers sshuser
Banner /etc/ssh/banner

# GRE-туннель (HQ-RTR)
mkdir /etc/net/ifaces/gre1
# /etc/net/ifaces/gre1/options:
# TUNLOCAL=172.16.1.x
# TUNREMOTE=172.16.2.x
# TUNTYPE=gre
# TYPE=iptun
# HOST=ens192

# OSPF через vtysh (FRR)
vtysh
conf t
router ospf
  passive-interface default
  network 172.16.100.0/29 area 0
  area 0 authentication
exit
interface gre1
  no ip ospf passive
  ip ospf authentication-key YOUR_KEY
exit
do wr
end

# DHCP-сервер
apt-get install -y dhcp-server

# DNS (bind9)
apt-get install -y bind bind-utils

# Samba DC
apt-get install -y task-samba-dc
samba-tool domain provision
systemctl enable --now samba

# RAID 0
mdadm --create --verbose /dev/md0 -l 0 -n 2 /dev/sdb /dev/sdc
mkfs.ext4 /dev/md0
mkdir /raid
# Добавить в /etc/fstab: /dev/md0 /raid ext4 defaults 0 0

# fail2ban
apt-get install -y fail2ban
# /etc/fail2ban/jail.local:
# [sshd]
# enabled = true
# port = 2026
# maxretry = 3
# bantime = 600
```
